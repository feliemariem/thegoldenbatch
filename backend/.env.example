# Database
DATABASE_URL=postgresql://username:password@localhost:5432/alumni_homecoming

# JWT Secret (generate a random string for production)
JWT_SECRET=your-super-secret-key-change-this

# Server
PORT=5000

# Google Forms Integration
# Generate a secure random string for the API key (e.g., openssl rand -hex 32)
GOOGLE_FORMS_API_KEY=your-google-forms-api-key

# OpenAI API Key (for future AI features)
OPENAI_API_KEY=your-openai-api-key